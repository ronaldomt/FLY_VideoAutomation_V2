{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "FLY Video Automation",
  "version": "0.1.0",
  "identifier": "com.tkotz.fly-video-automation",
  "build": {
    "beforeDevCommand": "pnpm --filter ./../ui dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm --filter ./../ui build",
    "frontendDist": "../ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "FLY Video Automation",
        "width": 1100,
        "height": 720,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "category": "Productivity",
    "copyright": "© Ronaldo Tkotz",
    "shortDescription": "Near-zero-click skydiving media ingest.",
    "longDescription": "Insert SD card / GoPro → local archive → extract frames → upload to Google Drive → share via WhatsApp.",
    "targets": ["dmg", "msi"],
    "externalBin": ["binaries/fly-backend"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
