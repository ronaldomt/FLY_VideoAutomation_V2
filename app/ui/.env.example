# Copy to .env.local to override the dev defaults.
#
# Defaults (when these vars are unset) match `backend/run-dev.sh`:
#   VITE_SIDECAR_URL=http://127.0.0.1:8000
#   VITE_SIDECAR_TOKEN=dev-token
#
# In the packaged Tauri app, the Rust shell injects window.__FLY_SIDECAR__
# from the runtime port file and these env vars are ignored.

# VITE_SIDECAR_URL=http://127.0.0.1:8000
# VITE_SIDECAR_TOKEN=dev-token
